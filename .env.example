# ─────────────────────────────────────────────────────────────
# NERAAJANS — Environment variables
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to version control.
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL). Matches docker-compose.yml defaults.
DATABASE_URL="postgresql://neraajans:neraajans_dev_pw@localhost:5432/neraajans?schema=public"

# NextAuth / Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
# Public base URL of the site (used for canonical URLs, OG, sitemap).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# Initial admin account (used by `npm run db:seed`)
ADMIN_EMAIL="admin@neraajans.com"
ADMIN_PASSWORD="ChangeMe!2026"
ADMIN_NAME="NERAAJANS Admin"

# Rate limiting. If set, uses Upstash Redis (correct across instances).
# Leave blank to use the in-memory fallback (fine for single-instance/dev).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# File storage. If set, uploads go to Vercel Blob (durable, serverless-safe).
# Leave blank to store uploads on local disk (/public/uploads) for dev.
BLOB_READ_WRITE_TOKEN=""

# Resend (transactional email). Leave blank in dev — emails log to console.
RESEND_API_KEY=""
# Address that quote-form notifications are sent to / from.
CONTACT_NOTIFICATION_EMAIL="info@neraajans.com"
EMAIL_FROM="NERAAJANS <onboarding@resend.dev>"
