// NERAAJANS — Prisma schema
// PostgreSQL (production on Vercel). Enums are modelled as validated strings
// and list fields (Work.services, ServicePage.*) as JSON strings, so the schema
// stays portable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Allowed string values (validated in app code via Zod):
//   Role:             ADMIN | EDITOR
//   ServiceType:      EDITORLUK | DIZGI | KAPAK_TASARIMI
//   SubmissionStatus: NEW | IN_REVIEW | CONTACTED | ARCHIVED

// ──────────────────────── Auth / Users ───────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String?
  role         String     @default("EDITOR")
  image        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  accounts     Account[]
  sessions     Session[]
  auditLogs    AuditLog[]
  blogPosts    BlogPost[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────── Blog ────────────────────────────────

model BlogCategory {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  posts       BlogPost[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("blog_categories")
}

model BlogPost {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String?
  content        String        // sanitized HTML from Tiptap
  coverImage     String?
  published      Boolean       @default(false)
  publishedAt    DateTime?
  readingMinutes Int           @default(3)

  categoryId     String?
  category       BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  authorId       String?
  author         User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  seoTitle       String?
  seoDescription String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([published, publishedAt])
  @@index([categoryId])
  @@map("blog_posts")
}

// ───────────────────── Çalışmalarımız (Works) ────────────────────

model Work {
  id             String      @id @default(cuid())
  title          String
  slug           String      @unique
  description    String
  coverImage     String?
  client         String?
  year           Int?
  services       String      @default("[]") // JSON array of ServiceType codes
  featured       Boolean     @default(false)
  published      Boolean     @default(true)
  order          Int         @default(0)

  images         WorkImage[]

  seoTitle       String?
  seoDescription String?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([published, featured, order])
  @@map("works")
}

model WorkImage {
  id     String  @id @default(cuid())
  url    String
  alt    String?
  order  Int     @default(0)
  workId String
  work   Work    @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
  @@map("work_images")
}

// ───────────────────────── Hizmetler ─────────────────────────────

model ServicePage {
  id               String   @id @default(cuid())
  key              String   @unique // ServiceType code
  title            String
  slug             String   @unique
  shortDescription String
  content          String?
  icon             String?
  order            Int      @default(0)

  // Rich, editable detail-page content. Lists are stored as JSON strings so the
  // same schema works on SQLite and PostgreSQL (mirrors Work.services).
  tagline          String?  // short eyebrow line
  intro            String?  // intro paragraph
  features         String   @default("[]") // JSON: { title, text }[]  ("Bu hizmet kapsamında")
  process          String   @default("[]") // JSON: { step, title, text }[]  ("Süreç")
  faqs             String   @default("[]") // JSON: { q, a }[]  ("Sıkça sorulan sorular")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("service_pages")
}

// ───────────────── Neden NERAAJANS (editable) ───────────────────
// Shown on the home "Neden NERAAJANS" section.

model WhyReason {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String   @default("sparkle") // key from components/ui/icon
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("why_reasons")
}

// ─────────────────── Teklif / İletişim form ──────────────────────

model ContactSubmission {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  serviceType String?  // ServiceType code
  message     String
  fileUrl     String?
  fileName    String?
  status      String   @default("NEW") // SubmissionStatus code
  ipHash      String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([status, createdAt])
  @@map("contact_submissions")
}

// ───────────────── Değerlerimiz / İlkeler (editable) ─────────────
// Shown on Hakkımızda ("Çalışma biçimimizi belirleyen ilkeler") and the
// home About section.

model ValueItem {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String   @default("badge") // key from lib/icons
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("value_items")
}

// ─────────────────────── Site / SEO settings ─────────────────────

model SiteSettings {
  id              String   @id @default("singleton")
  brandName       String   @default("NERAAJANS")
  slogan          String   @default("Kelimelerinize Profesyonel Bir Kimlik Kazandırıyoruz.")

  heroHeadline    String   @default("Kelimeleriniz Profesyonel Bir Tasarımla Buluşuyor.")
  heroSubheadline String

  aboutTitle      String   @default("Hakkımızda")
  aboutContent    String

  instagramUrl    String?
  facebookUrl     String?
  xUrl            String?
  linkedinUrl     String?
  youtubeUrl      String?

  internalEmail   String?
  updatedAt       DateTime @updatedAt

  @@map("site_settings")
}

model SEOSettings {
  id                 String   @id @default("singleton")
  defaultTitle       String   @default("NERAAJANS — Editörlük, Dizgi ve Kapak Tasarımı")
  titleTemplate      String   @default("%s · NERAAJANS")
  defaultDescription String
  keywords           String?
  ogImage            String?
  twitterHandle      String?
  updatedAt          DateTime @updatedAt

  @@map("seo_settings")
}

// ─────────────────────────── Audit log ───────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  ipHash    String?
  meta      String?  // JSON string
  createdAt DateTime @default(now())

  @@index([entity, createdAt])
  @@map("audit_logs")
}
